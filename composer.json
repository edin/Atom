{
    "name": "atom/framework",
    "description": "Atom Framework",
    "keywords": [
        "framework",
        "Atom"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "Atom\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atom\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M",
        "check": [
            "@analyse",
            "@test"
        ]
    }
}
